# ── Required ──────────────────────────────────────────────────────────────────
# Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional: OpenAI-compatible API ───────────────────────────────────────────
# For OpenAI, OpenRouter, Groq, Together AI, Mistral, etc.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Optional: Access Control ──────────────────────────────────────────────────
# Allow specific users (comma-separated Telegram usernames or IDs)
ALLOWED_USERS=

# Allow specific groups (comma-separated group IDs)
ALLOWED_GROUPS=

# Enable access control (1=enabled, 0=disabled)
AUCH_ENABLE=1

# ── Optional: Admin Settings ──────────────────────────────────────────────────
# Your Telegram user ID (get it from @userinfobot on Telegram)
ADMIN_ID=your_telegram_user_id

# Enable debug mode with admin logging (1=enabled, 0=disabled)
IS_DEBUG_MODE=0

# ── Optional: Model Configuration ─────────────────────────────────────────────
# Available Gemini models (comma-separated)
GEMINI_MODELS=gemini-2.0-flash,gemini-1.5-pro,gemini-1.5-flash

# Available OpenAI models (comma-separated)
OPENAI_MODELS=gpt-4o,gpt-4o-mini

# Default model to use
DEFAULT_MODEL=gemini-2.0-flash

# ── Optional: Group Mode ──────────────────────────────────────────────────────
# 1 = shared group history (all users see same context)
# 2 = per-user history within groups
GROUP_MODE=1
